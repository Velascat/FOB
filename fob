#!/usr/bin/env bash
# fob — forward operating base CLI
# Thin shell wrapper. Logic lives in src/fob/cli.py
set -euo pipefail

FOB_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VENV="$FOB_DIR/.venv"

# Auto-bootstrap Python environment on first run
if [[ ! -f "$VENV/bin/python3" ]]; then
  echo "▶ FOB: first run — setting up Python environment..."
  bash "$FOB_DIR/bootstrap.sh" || { echo "✗ Bootstrap failed." >&2; exit 1; }
  echo
fi

export PYTHONPATH="$FOB_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$VENV/bin/python3" -m fob.cli "$@"
